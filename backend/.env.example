# SettlementGuard Backend Environment Variables
# Copy this file to .env and fill in your values

# Signing key configuration (base64-encoded 32-byte Ed25519 seed)
SG_SIGNING_SEED_B64=replace_with_base64_encoded_32_byte_seed
SG_KEY_ID=sg-demo-key-01
SG_KEY_VERSION=v1

# Demo API protection
API_BEARER_TOKEN=replace_with_shared_demo_token
JSON_BODY_LIMIT=32kb
POST_RATE_LIMIT_MAX=60

# AWS Configuration (for AI reasoning via Bedrock)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SESSION_TOKEN=your_aws_session_token_if_using_temporary_credentials

# Bedrock AI Model
BEDROCK_MODEL_ID=us.amazon.nova-micro-v1:0

# ---------------------------------------------------------------------------
# Canton LocalNet / DevNet configuration
# ---------------------------------------------------------------------------

# Canton network mode: localnet | devnet
CANTON_NETWORK=localnet

# Enable/disable Canton anchoring
CANTON_ANCHORING_ENABLED=false

# Canton JSON Ledger API base URL
CANTON_LEDGER_API_URL=http://localhost:7575

# Optional bearer token or OAuth2 access token for secured Canton JSON Ledger API
CANTON_AUTH_TOKEN=

# Parties and package ID created after DAR upload / provisioning
CANTON_SUBMITTER_PARTY=
CANTON_CUSTODIAN_PARTY=
CANTON_PACKAGE_ID=

# Human-readable network label for UI/status
CANTON_NETWORK_LABEL=LocalNet

# ---------------------------------------------------------------------------
# Additional Canton / commitment registry configuration
# ---------------------------------------------------------------------------
CANTON_DOMAIN=global-synchronizer.canton.network
CANTON_PARTICIPANT=sg-participant-01

# Canton network profile — informational/configurational only.
# Allowed values: localnet | devnet | testnet | mainnet (default: localnet).
# The same JSON Ledger API client is used for every profile; the profile only
# describes which deployment target the operator has wired up so that
# /v1/canton/status reports `network_profile` and `devnet_ready` accurately.
# IMPORTANT: setting CANTON_NETWORK_PROFILE=devnet does NOT make DevNet "live".
# The status endpoint will only report `devnet_ready: true` once the configured
# DevNet validator actually responds to /livez. See docs/DEVNET.md.
CANTON_NETWORK_PROFILE=localnet

# Canton JWT Authentication
# CANTON_LEDGER_USER: the ledger API user (sub claim) — NOT the Daml party ID.
#   Per Canton KB: sub = ledger-api-user, parties go in actAs/readAs only.
CANTON_LEDGER_USER=sg-service-account

# Local sandbox only (HS256 — Canton sandbox with no auth does not need this):
CANTON_JWT_SECRET=

# Production (DevNet / TestNet / MainNet) — RS256 PEM private key.
#   Generate: openssl genrsa -out canton-jwt.pem 2048
#   Configure Canton participant with the matching public key via OIDC provider.
#   Per Canton KB: "Production: JWT (RS256). Configure OIDC provider (Auth0, Keycloak)."
CANTON_JWT_PRIVATE_KEY=
CANTON_JWT_AUDIENCE=https://daml.com/ledger-api

# ---------------------------------------------------------------------------
# Commitment registry storage
# DynamoDB is the primary store; SQLite is the local fallback.
# ---------------------------------------------------------------------------
DYNAMO_TABLE=sg-commitment-registry

# Application Settings
PORT=3001
NODE_ENV=development
