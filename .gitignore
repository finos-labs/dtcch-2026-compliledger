# .gitignore
#
#   This file specifies intentionally untracked files that Git should ignore.

# Environment variables
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
*.pid
*.seed
*.pid.lock
data/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~

# Temporary files
*.tmp
.cache/

# Testing
coverage/
.nyc_output/

# Canton / Local development artifacts
canton/.daml/
canton/cn-quickstart/
backend/.env.canton
backend/data/

# Archive
archive/

# Miscellaneous
~$*.*